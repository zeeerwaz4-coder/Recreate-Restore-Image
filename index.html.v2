<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>AI Restoration</title>

  <link rel="stylesheet" href="style.css">
</head>
<body>

<div class="topbar">
  <div class="logo">AI</div>
  <div class="title">AI RESTORATION</div>
</div>

<div class="canvas">CANVAS AREA</div>

<div class="inputBox">
  <input type="text" placeholder="type audio..." />
</div>

<div class="floatAI">AI</div>

<div class="sectionTitle">INSTA AI TOOLS</div>

<div class="scrollRow">
  <div class="card">Tool 1</div>
  <div class="card">Tool 2</div>
  <div class="card">Tool 3</div>
</div>

<div class="bottomTools">
  <div class="toolsScroll" id="tools">
    <div class="tool">Enhance</div>
    <div class="tool">Restore</div>
    <div class="tool">Face AI</div>
  </div>
</div>

<script src="script.js"></script>

</body>
</html>
